				aside(class='v2-glass flex flex-col rounded-[28px] border border-white/10 p-5')
					div(class='flex items-start justify-between gap-3')
						div
							p(class='text-xs font-semibold uppercase tracking-[0.24em] text-slate-400')= L('serverList')
							h2(class='mt-2 text-2xl font-black text-white') 서버 현황
							p#v2-server-total(class='mt-2 text-sm text-slate-300')= L('LOADING')
						button#v2-refresh(type='button', class='inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-lg text-white transition hover:border-cyan/50 hover:bg-cyan/10', aria-label=L('serverRefresh'))
							i.fa.fa-refresh
					div(class='mt-4 flex items-center justify-between rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-300')
						span#v2-refresh-status= L('serverRefresh')
						span#v2-last-updated(class='text-slate-400') --:--:--
					div#v2-server-list(class='v2-scroll mt-4 flex max-h-[480px] flex-col gap-3 overflow-y-auto pr-1')
						div(class='rounded-2xl border border-dashed border-white/10 bg-white/5 p-4 text-sm text-slate-400') 서버 상태를 불러오는 중입니다.
		div(class='mt-6 grid gap-6 lg:grid-cols-[minmax(0,1fr)_300px]')
			section(class='v2-glass overflow-hidden rounded-[28px] border border-white/10')
				div(class='flex items-center justify-between border-b border-white/10 px-5 py-4')
					div
						p(class='text-xs font-semibold uppercase tracking-[0.24em] text-slate-400') Bulletin
						h2(class='text-xl font-black text-white') 공지와 업데이트
					span(class='rounded-full border border-cyan/30 bg-cyan/10 px-3 py-1 text-xs font-semibold text-cyan') 실시간 안내
				iframe#v2-bulletin(class='h-[420px] w-full bg-white', src='/kkutu_bulletin.html')
			aside(class='v2-glass rounded-[28px] border border-white/10 p-5')
				div(class='space-y-4')
					div
						p(class='text-xs font-semibold uppercase tracking-[0.24em] text-slate-400') Guide
						h2(class='text-xl font-black text-white') 빠른 안내
					ul(class='space-y-3 text-sm leading-6 text-slate-300')
						li 서버 카드에 포트가 표시되면 현재 운영 포트 기준으로 연결 중인 서버입니다.
						li 회색 카드는 응답이 없는 서버이며, 입장 버튼이 비활성화됩니다.
						li 빠른 입장은 로그인 여부와 혼잡도를 기준으로 자동 추천 서버를 선택합니다.
					div(class='rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-slate-300')
						p(class='font-semibold text-white') 언어 선택
						div(class='mt-3 flex flex-wrap gap-2')
							a(class='rounded-full border border-white/10 px-3 py-2 text-sm text-white transition hover:border-cyan/50 hover:bg-cyan/10', href="javascript:setParam('locale', 'ko_KR');") 한국어
							a(class='rounded-full border border-white/10 px-3 py-2 text-sm text-white transition hover:border-cyan/50 hover:bg-cyan/10', href="javascript:setParam('locale', 'en_US');") English

block Bottom
	div.bottom-legal!= L('dictionarySupport')
	div.bottom-legal!= L('etcSupport')
	script.
		function setParam(name, value) {
			var l = window.location;
			var params = {};
			var matcher = /(?:\??)([^=&?]+)=?([^&?]*)/g;
			var search = l.search;
			for (var result = matcher.exec(search); result; result = matcher.exec(search)) {
				result[1] = decodeURIComponent(result[1]);
				if (!result[2]) result[2] = '%%';
				params[result[1]] = result[2];
			}
			params[name] = encodeURIComponent(value);
			search = [];
			for (var key in params) {
				var part = encodeURIComponent(key);
				var paramValue = params[key];
				if (paramValue != '%%') part += '=' + paramValue;
				search.push(part);
			}
			l.search = search.join('&');
		}
