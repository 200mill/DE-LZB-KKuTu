extends layout

block Subject
	title 끄투 관리 페이지

block CSS
	script(src='https://cdn.tailwindcss.com')
	script.
		tailwind.config = {
			theme: {
				extend: {
					colors: {
						tide: '#020617',
						panel: '#081225',
						mist: '#dbeafe',
						cyan: '#67e8f9',
						signal: '#fb923c'
					},
					boxShadow: {
						glow: '0 24px 80px rgba(34, 211, 238, 0.16)'
					}
				}
			}
		};
	style.
		body {
			min-width: 640px;
			background:
				radial-gradient(circle at top left, rgba(34, 211, 238, 0.16), transparent 28%),
				radial-gradient(circle at 88% 16%, rgba(251, 146, 60, 0.14), transparent 25%),
				linear-gradient(180deg, #020617 0%, #07101f 54%, #0f172a 100%);
			color: #e2e8f0;
			font-family: "Pretendard", "SUIT Variable", "Noto Sans KR", "Malgun Gothic", sans-serif;
		}
		#Background {
			display: none;
		}
		#Top, #Middle, #Bottom {
			position: relative;
			z-index: 1;
		}
		.admin-grid-bg {
			background-image:
				linear-gradient(rgba(148, 163, 184, 0.08) 1px, transparent 1px),
				linear-gradient(90deg, rgba(148, 163, 184, 0.08) 1px, transparent 1px);
			background-size: 34px 34px;
		}
		.admin-glass {
			background: rgba(8, 18, 37, 0.76);
			backdrop-filter: blur(18px);
		}
		.admin-scroll::-webkit-scrollbar {
			width: 8px;
			height: 8px;
		}
		.admin-scroll::-webkit-scrollbar-thumb {
			background: rgba(148, 163, 184, 0.35);
			border-radius: 999px;
		}
		#Middle input,
		#Middle textarea,
		#Middle select {
			background: rgba(15, 23, 42, 0.85);
			border: 1px solid rgba(148, 163, 184, 0.28);
			color: #e2e8f0;
			border-radius: 0.8rem;
			padding: 0.6rem 0.75rem;
		}
		#Middle button {
			border-radius: 0.8rem;
			padding: 0.55rem 0.9rem;
			font-weight: 700;
			background: rgba(103, 232, 249, 0.18);
			border: 1px solid rgba(103, 232, 249, 0.35);
			color: #e2e8f0;
			transition: all .18s ease;
		}
		#Middle button:hover {
			background: rgba(103, 232, 249, 0.28);
			border-color: rgba(103, 232, 249, 0.52);
		}
		#Middle table {
			width: 100%;
			min-width: 760px;
			border-collapse: separate;
			border-spacing: 0;
		}
		#Middle thead td {
			position: sticky;
			top: 0;
			z-index: 1;
			background: rgba(15, 23, 42, 0.95);
			color: #93c5fd;
			font-size: 0.78rem;
			font-weight: 700;
			padding: 0.62rem 0.5rem;
			border-bottom: 1px solid rgba(148, 163, 184, 0.28);
		}
		#Middle tbody td {
			padding: 0.45rem 0.5rem;
			border-bottom: 1px solid rgba(148, 163, 184, 0.14);
			vertical-align: top;
		}
		#Middle tbody tr:hover {
			background: rgba(30, 41, 59, 0.46);
		}
		#Middle h5 {
			color: #cbd5e1;
			line-height: 1.65;
		}

block JS
	script(type="text/javascript", src="/js/in_admin.min.js")
	
block Middle
	div(class='mx-auto max-w-[1600px] px-4 pb-14 pt-8 sm:px-6 lg:px-8')
		div(class='relative overflow-hidden rounded-[30px] border border-white/10 shadow-glow')
			div(class='absolute inset-0 bg-gradient-to-br from-cyan/20 via-transparent to-signal/10')
			div(class='admin-grid-bg absolute inset-0 opacity-40')
			div(class='relative min-w-0 space-y-6 px-5 py-6 lg:px-8 lg:py-8')
				div(class='flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between')
					div
						p(class='text-xs font-semibold uppercase tracking-[0.28em] text-cyan/90') Admin Console
						h1(class='mt-2 text-3xl font-black text-white sm:text-4xl') 끄투 관리 페이지
						p(class='mt-3 text-sm leading-6 text-slate-300') DB 조회, 승인, 사용자 관리 기능을 하나의 대시보드로 정리했습니다.
					div(class='admin-glass rounded-2xl border border-white/10 p-4 sm:min-w-[360px]')
						p(class='text-xs font-semibold uppercase tracking-[0.24em] text-slate-400') 자격
						div(class='mt-3 grid gap-2 sm:grid-cols-2')
							input#db-password(type='password', placeholder='암호')
							input#db-lang(placeholder='테이블')

				fieldset(class='admin-glass min-w-0 w-full rounded-3xl border border-white/10 p-4 sm:p-5')
					legend(class='px-2 text-sm font-semibold tracking-[0.12em] text-cyan/90') 추가 요청 받기
					div(class='mt-3 flex flex-wrap gap-2')
						button#injeong-go(type='button') 조회
						button#injeong-everything(type='button') 모두 승인
						button#injeong-nothing(type='button') 모두 거절
						button#injeong-apply(type='button', class='bg-signal/20 border-signal/40 hover:bg-signal/30') 적용
					div(class='admin-scroll mt-4 w-full overflow-x-auto rounded-2xl border border-white/10')
						table
							thead: tr
								td 승인?
								td 링크
								td 단어
								td 주제
								td 한사람
								td 언제
							tbody#injeong-data

				fieldset(class='admin-glass min-w-0 w-full rounded-3xl border border-white/10 p-4 sm:p-5')
					legend(class='px-2 text-sm font-semibold tracking-[0.12em] text-cyan/90') 상점 DB 다루기
					div(class='mt-3 flex flex-wrap gap-2')
						input#shop-word(class='min-w-[240px] flex-1', placeholder='품목 ("~ALL" ⮕ 항목 전체)')
						button#shop-go(type='button') 조회
						button#shop-hide(type='button') 숨기기
						button#shop-add(type='button') 추가
						button#shop-apply(type='button', class='bg-signal/20 border-signal/40 hover:bg-signal/30') 적용
					div(class='admin-scroll mt-4 w-full overflow-x-auto rounded-2xl border border-white/10')
						table
							thead: tr
								td #
								td 가격
								td 산횟수
								td term
								td 종류
								td 업데이트날짜
								td 장착효과
								td 한국어이름
								td 한국어설명
								td 영어이름
								td 영어설명
							tbody#shop-data

				fieldset(class='admin-glass min-w-0 w-full rounded-3xl border border-white/10 p-4 sm:p-5')
					legend(class='px-2 text-sm font-semibold tracking-[0.12em] text-cyan/90') 유저 DB 다루기
					div(class='mt-3 flex flex-wrap gap-2')
						input#user-id(placeholder='ID')
						input#user-nick(placeholder='닉네임')
						button#user-go(type='button') 조회
						button#user-apply(type='button', class='bg-signal/20 border-signal/40 hover:bg-signal/30') 적용
					div(class='admin-scroll mt-4 w-full overflow-x-auto rounded-2xl border border-white/10')
						table
							thead: tr
								td #
								td 돈
								td 전적
								td 인벤토리
								td 장착중
								td 닉네임
								td 닉네임 변경날짜
								td 소개글
								td 서버
								td 마지막 접속
								td 밴사유
								td 밴끝(없으면 무기한)
								td 친구
							tbody#user-data

				fieldset(class='admin-glass min-w-0 w-full rounded-3xl border border-white/10 p-4 sm:p-5')
					legend(class='px-2 text-sm font-semibold tracking-[0.12em] text-cyan/90') 유저 감시하기
					div(class='mt-3 flex flex-wrap gap-2')
						input#gamsi-id(class='min-w-[240px] flex-1', placeholder='ID (,로 구분)')
						button#gamsi-go(type='button') 감시
					div(class='admin-scroll mt-4 w-full overflow-x-auto rounded-2xl border border-white/10')
						table
							thead: tr
								td #
								td 닉네임
								td 서버
							tbody#gamsi-data

				fieldset(class='admin-glass min-w-0 w-full rounded-3xl border border-white/10 p-4 sm:p-5')
					legend(class='px-2 text-sm font-semibold tracking-[0.12em] text-cyan/90') 끄투 DB 다루기
					div(class='mt-3 flex flex-wrap gap-2')
						input#db-word(class='min-w-[220px] flex-1', placeholder='단어')
						input#wd-flag(placeholder='flag')
						button#db-go(type='button') 조회
						button#word-add(type='button') 추가
						button#db-apply(type='button', class='bg-signal/20 border-signal/40 hover:bg-signal/30') 적용
					div#word-data(class='mt-4 min-w-0 rounded-2xl border border-white/10 p-3')
						div#wd-id(class='mb-3 text-sm text-slate-300')
						div(class='admin-scroll w-full overflow-x-auto rounded-2xl border border-white/10')
							table
								thead: tr
									td #
									td 타입
									td 주제
									td 뜻
									td 행동
								tbody#wd-data
					div#word-flag(class='mt-3 text-sm text-slate-400')
					div#word-hit(class='mt-1 text-sm text-slate-400')

				fieldset(class='admin-glass min-w-0 w-full rounded-3xl border border-white/10 p-4 sm:p-5')
					legend(class='px-2 text-sm font-semibold tracking-[0.12em] text-cyan/90') 끄투 DB에 단어 추가하기
					h5
						| OK가 안뜨면 1000개가 넘지는 않았는지, 비밀번호, 테이블(ko혹은 en),
						a(class='ml-1 text-cyan underline underline-offset-4', href='/daneodb/list.txt', target='_blank') 주제
						| 가 올바른지 확인해보자
					div(class='mt-3 flex flex-wrap gap-2')
						input#db-theme(class='min-w-[240px] flex-1', placeholder='주제 ("~주제" ⮕ 주제 전체)')
						button#db-ok(type='button', class='bg-signal/20 border-signal/40 hover:bg-signal/30') 확인
					textarea#db-list(class='admin-scroll mt-3 w-full rounded-2xl border border-white/10 bg-slate-950/50 p-3 text-sm leading-6', rows=20, cols=100, placeholder='단어 목록 (한 줄에 하나씩 1000개씩)')

				fieldset(class='admin-glass min-w-0 w-full rounded-3xl border border-white/10 p-4 sm:p-5')
					legend(class='px-2 text-sm font-semibold tracking-[0.12em] text-cyan/90') 끄투에서의 인기 단어
					div(class='mt-3 flex flex-wrap gap-2')
						button#kpw-query(type='button') 조회
						button#kpw-flush(type='button', class='bg-signal/20 border-signal/40 hover:bg-signal/30') 반영
					textarea#kpw-html(class='admin-scroll mt-3 w-full rounded-2xl border border-white/10 bg-slate-950/50 p-3 text-sm leading-6', rows=8)
					div#kpw-table(class='admin-scroll mt-3 overflow-auto rounded-2xl border border-white/10 p-3')
