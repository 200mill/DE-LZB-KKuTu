//- todo - ui 개선 - 진행 중
extends layout

block Subject
	title 단어 검색기

block CSS
	link(rel='stylesheet', href='/css/in_search.css')

block JS
	script(type="text/javascript", src="/js/in_search.js", defer)

block Middle
	h1 검색할 단어를 선택하세요.
	h4 오류가 있을 수 있습니다. 제보해주시면 감사 하겠습니다.
	div.theme-buttons
		- var themes = (typeof KO_INJEONG !== 'undefined' && Array.isArray(KO_INJEONG)) ? KO_INJEONG : [];
		- for(var i = 0; i < themes.length; i++)
			- var rawCode = themes[i] || '';
			- var themeCode = String(rawCode).toLowerCase();
			- var localeKey = 'theme_' + String(rawCode).toUpperCase();
			- var themeLabel = (typeof locale !== 'undefined' && locale[localeKey]) ? locale[localeKey] : rawCode;
			button.theme-btn(data-theme=themeCode)= themeLabel
		- if(!themes.length)
			p.message 주제 데이터가 없습니다.
	div.word-list-container
		p.message#initial-message 단어 주제를 선택해주세요.
		ul#word-list